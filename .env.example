# ==============================================================================
# 1. ROTEAMENTO GLOBAL E SEGURANÇA (TRAEFIK)
# ==============================================================================
# Domínio base para todas as aplicações (ex: capela.com.br)
DOMAIN=seudominio.com.br
# Email válido obrigatório para a emissão dos certificados SSL Let's Encrypt
ADMIN_EMAIL=admin@seudominio.com.br

# Credenciais de acesso ao Dashboard do Traefik.
# O formato exige criptografia MD5, SHA1 ou BCrypt.
# Comando para gerar a hash no terminal Linux: echo $(htpasswd -nB seu_usuario) | sed -e s/\\$/\\$\\$/g
TRAEFIK_AUTH=admin:$$apr1$$H6uskkkW$$IgXLP6ewTrSuBkTrqE8wj/

# ==============================================================================
# 2. CREDENCIAIS CORE (MOTORES DE INFRAESTRUTURA)
# ==============================================================================
POSTGRES_ROOT_PASS=senha_super_admin_postgres_123
REDIS_PASS=senha_super_admin_redis_123
MINIO_ROOT_USER=admin_minio
MINIO_ROOT_PASS=senha_super_admin_minio_123

# ==============================================================================
# 3. SENHAS DE ISOLAMENTO (BANCOS DE DADOS APLICAÇÕES)
# ==============================================================================
# Estas variáveis alimentam o script 'init-databases.sh' no primeiro boot
DB_PASS_EVOLUTION=senha_isolada_evo_123
DB_PASS_CHATWOOT=senha_isolada_chatwoot_123
DB_PASS_TYPEBOT=senha_isolada_typebot_123
DB_PASS_N8N=senha_isolada_n8n_123

# ==============================================================================
# 4. PARÂMETROS EXCLUSIVOS DO N8N (HERDADOS DA ÂNCORA)
# ==============================================================================
POSTGRES_DB=n8n_db
POSTGRES_NON_ROOT_USER=n8n_user
# Esta variável alimenta a string de conexão do contêiner do n8n.
# DEVE ser estritamente igual à DB_PASS_N8N definida acima.
POSTGRES_NON_ROOT_PASSWORD=senha_isolada_n8n_123

# Chaves de segurança internas do motor de orquestração
ENCRYPTION_KEY=chave_criptografica_n8n_super_secreta_123
RUNNERS_AUTH_TOKEN=token_autenticacao_runners_super_secreto_123